---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
}

const { title, date } = Astro.props;

const formattedDate = date.toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<Base title={title}>
  <article>
    <div class="post-header">
      <h1>{title}</h1>
      <time datetime={date.toISOString()}>{formattedDate}</time>
    </div>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>
